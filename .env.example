# ============================================
# HumanPrism 환경 변수 설정 가이드
# ============================================
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# 프로덕션 환경에서는 환경 변수를 시스템에 직접 설정하세요.

# ============================================
# 필수 환경 변수 (반드시 설정)
# ============================================

# 데이터베이스 연결 문자열 (MySQL/TiDB)
# 예: mysql://user:password@localhost:3306/humanprism
DATABASE_URL=

# Node 환경 (development/production)
NODE_ENV=development

# JWT 쿠키 서명 시크릿 (32자 이상 권장)
JWT_SECRET=

# Manus OAuth 애플리케이션 ID
VITE_APP_ID=

# Manus OAuth 서버 URL
OAUTH_SERVER_URL=

# 운영자 OpenID (Manus 사용자 ID)
OWNER_OPEN_ID=

# ============================================
# Manus 내장 API (Manus 플랫폼 전용)
# ============================================
# Bolt.new로 이관 시 Anthropic API로 교체 필요

# Manus Forge API URL (LLM, 스토리지, 알림 등)
BUILT_IN_FORGE_API_URL=

# Manus Forge API 키 (서버 사이드)
BUILT_IN_FORGE_API_KEY=

# Manus Forge API 키 (클라이언트 사이드)
VITE_FRONTEND_FORGE_API_KEY=

# Manus Forge API URL (클라이언트 사이드)
VITE_FRONTEND_FORGE_API_URL=

# ============================================
# Claude API (프롬프트 캐싱 포함)
# ============================================
# Anthropic 콘솔에서 발급: https://console.anthropic.com
# 중요: 프롬프트 캐싱 설정이 활성화되어 있는지 확인

CLAUDE_API_KEY=

# ============================================
# 카카오/네이버 간편 로그인
# ============================================

# 카카오 REST API 키
# 카카오 개발자 콘솔: https://developers.kakao.com
KAKAO_REST_API_KEY=

# 카카오 클라이언트 시크릿
KAKAO_CLIENT_SECRET=

# 네이버 클라이언트 ID
# 네이버 개발자 콘솔: https://developers.naver.com
NAVER_CLIENT_ID=

# 네이버 클라이언트 시크릿
NAVER_CLIENT_SECRET=

# ============================================
# 포트원(Portone) V2 결제 연동
# ============================================
# 포트원 콘솔: https://admin.portone.io
# 현재 상태: 심사 대기 중 (수동 승인 흐름 사용)

# 포트원 스토어 ID
PORTONE_STORE_ID=

# 포트원 API 시크릿
PORTONE_API_SECRET=

# 포트원 채널 키 (PG 채널 연동 후 발급)
PORTONE_CHANNEL_KEY=

# ============================================
# SMS 발송 (솔라피 SOLAPI)
# ============================================
# 알리고는 IP 고정 정책으로 클라우드 환경 불가
# 솔라피 콘솔: https://solapi.com

# 솔라피 API Key (모든 IP 허용으로 발급)
SOLAPI_API_KEY=

# 솔라피 API Secret (HMAC-SHA256 서명용)
SOLAPI_API_SECRET=

# 등록·인증된 발신번호 (하이픈 없이, 예: 01044488064)
SOLAPI_SENDER=

# 마스터 수신 휴대폰 (알림 받을 번호)
MASTER_SMS_TO=

# ============================================
# 관리자 설정
# ============================================

# 관리자 이메일 목록 (쉼표로 구분)
# 이 이메일로 로그인하면 자동으로 admin 역할 부여
ADMIN_EMAILS=

# 관리자 OpenID 목록 (쉼표로 구분)
# 예: kakao:123456,naver:abc123
ADMIN_OPENIDS=

# ============================================
# 공개 도메인 설정
# ============================================
# OAuth redirect_uri 고정용
# 프록시 뒤에서 host 헤더가 내부 주소로 잡히는 환경에서 사용
# 예: https://human-prism.com

PUBLIC_BASE_URL=

# ============================================
# 선택사항: 웹사이트 제목 및 로고
# ============================================

# 웹사이트 제목 (브라우저 탭, SEO 등)
VITE_APP_TITLE=HumanPrism

# 웹사이트 로고 URL
VITE_APP_LOGO=

# ============================================
# 선택사항: 분석 및 모니터링
# ============================================

# 분석 엔드포인트 (Manus 내장 또는 외부)
VITE_ANALYTICS_ENDPOINT=

# 분석 웹사이트 ID
VITE_ANALYTICS_WEBSITE_ID=
