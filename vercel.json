{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "routes": [
    {
      "src": "/share/(.+)",
      "dest": "https://humanprism-production.up.railway.app/share/$1",
      "headers": {
        "Accept": "text/html"
      }
    },
    {
      "src": "/api/(.+)",
      "dest": "https://humanprism-production.up.railway.app/api/$1"
    },
    {
      "src": "/trpc/(.+)",
      "dest": "https://humanprism-production.up.railway.app/trpc/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
