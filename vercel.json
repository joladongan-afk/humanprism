{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/share-og.ts": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/share/:token",
      "destination": "/api/share-og?token=:token"
    },
    {
      "source": "/api/:path*",
      "destination": "https://humanprism-production.up.railway.app/api/:path*"
    },
    {
      "source": "/trpc/:path*",
      "destination": "https://humanprism-production.up.railway.app/trpc/:path*"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
