{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "routes": [
    {
      "src": "/api/share/(.*)",
      "dest": "/api/share/[token]?token=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://humanprism-production.up.railway.app/api/$1"
    },
    {
      "src": "/trpc/(.*)",
      "dest": "https://humanprism-production.up.railway.app/trpc/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
